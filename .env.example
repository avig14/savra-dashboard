# ============================================================
# Savra Dashboard — Environment Variables
# Copy this file to .env.local and fill in real values
# ============================================================

# ------ Supabase (PostgreSQL) ------
# From: Supabase Dashboard → Settings → Database → Connection String
# Transaction pooler (for Vercel serverless API routes)
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# Direct connection (for Prisma migrations ONLY — never used at runtime)
DIRECT_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].supabase.com:5432/postgres"

# ------ Anthropic API (AI Insights) ------
# From: console.anthropic.com → API Keys
# If not set, AI insights show a static fallback (no crash)
ANTHROPIC_API_KEY="sk-ant-..."

# ------ Auth.js v5 ------
# Generate: npx auth secret   (or: openssl rand -base64 32)
AUTH_SECRET="your-32-char-secret-here"

# Set to your deployment URL in production
AUTH_URL="http://localhost:3000"

# ------ Demo Credentials ------
# Login at /login with:
# Username: admin
# Password: admin123
